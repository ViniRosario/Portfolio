rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a portfolio-based security model for Vini Rosário's portfolio.
     * It distinguishes between public read-only content and admin-managed data.
     * 
     * DATA STRUCTURE
     * - Public Collections: /userProfile, /skills, /tools, /portfolioVideos are globally readable.
     * - Write-Only Sink: /contactMessages allows any user to submit data, but only admins can view it.
     * - RBAC: Admin status is determined via a Database Access Control (DBAC) pattern 
     *   stored in the /roles_admin/{uid} collection.
     * 
     * KEY SECURITY DECISIONS
     * - Admin roles are strictly verified by document existence in the roles_admin collection.
     * - Most write operations require an 'Admin' privilege.
     * - Contact messages are treated as sensitive data, restricted to admin eyes only.
     * - Relational integrity is enforced by matching path IDs to internal document IDs where applicable.
     * 
     * DENORMALIZATION FOR AUTHORIZATION
     * To ensure fast rules, the admin check utilizes a direct lookup on the roles_admin collection 
     * using the authenticated user's UID, avoiding complex nested queries or group checks.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated with any provider. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user has an entry in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Combines admin check with a verification that the target document exists. */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Publicly readable profile details. Managed by administrators.
     * @path /userProfile/{userProfileId}
     * @allow get, list: if true; (Public Access)
     * @allow create: if isAdmin() && request.resource.data.id == userProfileId;
     * @deny create: if !isAdmin(); (Unauthorized attempt to edit portfolio)
     * @principle Public consumption with administrative control and ID consistency.
     */
    match /userProfile/{userProfileId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == userProfileId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Collection of skills. Publicly viewable, admin modifiable.
     * @path /skills/{skillId}
     * @allow get, list: if true;
     * @allow update: if isExistingAdmin();
     * @deny delete: if !isAdmin();
     * @principle Publicly accessible content with owner-only writes.
     */
    match /skills/{skillId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == skillId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Collection of tools/tech. Publicly viewable, admin modifiable.
     * @path /tools/{toolId}
     * @allow get, list: if true;
     * @allow create: if isAdmin();
     * @deny update: if request.auth == null;
     * @principle Publicly accessible content with owner-only writes.
     */
    match /tools/{toolId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == toolId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Portfolio video gallery. Publicly viewable, admin modifiable.
     * @path /portfolioVideos/{videoId}
     * @allow get, list: if true;
     * @allow create: if isAdmin();
     * @deny delete: if !isAdmin();
     * @principle Publicly accessible content with owner-only writes.
     */
    match /portfolioVideos/{videoId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == videoId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Contact form submissions. Public users can create; Admins can manage.
     * @path /contactMessages/{messageId}
     * @allow create: if true; (Publicly accessible contact form)
     * @allow list: if isAdmin(); (Privacy protection for sender data)
     * @deny get: if !isAdmin(); (User privacy)
     * @principle Public write-only access for feedback/leads with admin-only read access.
     */
    match /contactMessages/{messageId} {
      allow create: if true;
      allow get, list: if isAdmin();
      allow update: if isExistingAdmin();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Database Access Control (DBAC) registry for administrators.
     * @path /roles_admin/{uid}
     * @allow get: if isSignedIn() && request.auth.uid == uid;
     * @deny create, update, delete: if true; (Admin roles should be managed via console or secure backend)
     * @principle Restricted lookup-based authorization mapping.
     */
    match /roles_admin/{uid} {
      allow get: if isSignedIn() && request.auth.uid == uid;
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }
  }
}